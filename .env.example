# ─── Base de données ──────────────────────────────────────────────────────────
# Récupérer sur : https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://UTILISATEUR:MOT_DE_PASSE@cluster0.xxxxx.mongodb.net/top-service?retryWrites=true&w=majority

# ─── JWT — Secrets de signature ───────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET=REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_64_CHARS
JWT_REFRESH_SECRET=REMPLACER_PAR_UNE_AUTRE_CHAINE_ALEATOIRE_64_CHARS

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Récupérer sur : https://console.upstash.com → Database → REST API
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=VOTRE_TOKEN_UPSTASH

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
